// VyapaarX — Production Prisma Schema
// Relation field names use camelCase (Prisma convention) so that all service
// include/select queries work without capitalisation mismatches.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  password     String?
  businessName String?
  phone        String?
  avatar       String?
  role         String  @default("admin")
  isActive     Boolean @default(true)
  gstNumber    String?

  // Address fields (flat — no nested object)
  street  String?
  city    String?
  state   String?
  pincode String?
  country String? @default("India")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations — camelCase
  products        Product[]
  customers       Customer[]
  orders          Order[]
  invoices        Invoice[]
  suppliers       Supplier[]
  businessConfig  BusinessConfig?
  cashbookEntries CashbookEntry[]
  staff           Staff[]

  @@map("User")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────────────────────────────────────────
model Product {
  id                String  @id @default(uuid())
  userId            String
  name              String
  sku               String  @unique
  description       String?
  category          String?
  price             Float
  costPrice         Float?
  stock             Int     @default(0)
  lowStockThreshold Int     @default(10)
  unit              String  @default("pcs")
  images            String[]
  gstRate           Float   @default(18)
  isActive          Boolean @default(true)
  tags              String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  orderItems   OrderItem[]
  invoiceItems InvoiceItem[]

  @@map("Product")
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────────────────────────────────────
model Customer {
  id       String  @id @default(uuid())
  userId   String
  name     String
  email    String?
  phone    String?
  type     String  @default("retail")
  gstin    String?
  tags     String[]
  isActive Boolean @default(true)

  // Flat address
  street  String?
  city    String?
  state   String?
  zipCode String?
  country String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  orders   Order[]
  invoices Invoice[]

  @@map("Customer")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────────────────────────────────────
model Order {
  id          String  @id @default(uuid())
  userId      String
  customerId  String?
  orderNumber String  @unique
  subtotal    Float
  gstAmount   Float   @default(0)
  discount    Float   @default(0)
  total       Float

  status        String  @default("pending")
  paymentStatus String  @default("unpaid")
  paymentMethod String?

  // Shipping address
  street  String?
  city    String?
  state   String?
  pincode String?

  notes       String?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  invoices Invoice[]

  @@map("Order")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDER ITEM
// ─────────────────────────────────────────────────────────────────────────────
model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  productId String
  name      String
  quantity  Int
  price     Float
  gstRate   Float  @default(18)
  total     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("OrderItem")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────────────────────────────────────
model Invoice {
  id            String  @id @default(uuid())
  userId        String
  orderId       String?
  invoiceNumber String  @unique
  customerId    String
  supplierId    String?
  subtotal      Float
  gstAmount     Float
  cgst          Float   @default(0)
  sgst          Float   @default(0)
  igst          Float   @default(0)
  totalAmount   Float
  paymentStatus String  @default("UNPAID")
  paymentMethod String?
  status        String  @default("draft")
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  customer   Customer    @relation(fields: [customerId], references: [id])
  order      Order?      @relation(fields: [orderId], references: [id])
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])
  items      InvoiceItem[]
  payments   Payment[]
  taxRecords TaxRecord[]

  @@map("Invoice")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICE ITEM
// ─────────────────────────────────────────────────────────────────────────────
model InvoiceItem {
  id        String @id @default(uuid())
  invoiceId String
  productId String
  quantity  Int
  price     Float
  discount  Float  @default(0)
  gstRate   Float  @default(18)
  hsnCode   String?
  total     Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("InvoiceItem")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────────────────────────────────────
model Payment {
  id              String @id @default(uuid())
  invoiceId       String
  amount          Float
  paymentMethod   String
  referenceNumber String?
  paymentDate     DateTime @default(now())

  status           String @default("SUCCESS")
  upiId            String?
  razorpayId       String?
  payerName        String?
  settlementStatus String @default("SETTLED")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("Payment")
}

// ─────────────────────────────────────────────────────────────────────────────
// TAX RECORD
// ─────────────────────────────────────────────────────────────────────────────
model TaxRecord {
  id        String @id @default(uuid())
  invoiceId String
  taxType   String
  rate      Float
  amount    Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("TaxRecord")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPLIER
// ─────────────────────────────────────────────────────────────────────────────
model Supplier {
  id           String @id @default(uuid())
  userId       String
  supplierCode String @unique
  name         String
  email        String?
  phone        String?
  gstNumber    String?
  panNumber    String?
  address      String?
  city         String?
  state        String?
  country      String? @default("India")
  pincode      String?
  status       String  @default("ACTIVE")
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  invoices Invoice[]

  @@map("Supplier")
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS CONFIG / SETTINGS
// ─────────────────────────────────────────────────────────────────────────────
model BusinessConfig {
  id            String @id @default(uuid())
  userId        String @unique
  gstin         String?
  pan           String?
  bankName      String?
  accountNo     String?
  ifscCode      String?
  invoicePrefix String @default("INV")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("BusinessConfig")
}

// ─────────────────────────────────────────────────────────────────────────────
// CASHBOOK
// ─────────────────────────────────────────────────────────────────────────────
model CashbookEntry {
  id       String @id @default(uuid())
  userId   String
  type     String
  category String
  amount   Float
  notes    String?
  date     DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("CashbookEntry")
}

// ─────────────────────────────────────────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────────────────────────────────────────
model Staff {
  id          String @id @default(uuid())
  userId      String
  name        String
  email       String
  phone       String
  role        String
  department  String   @default("Logistics")
  salary      Float    @default(30000)
  joiningDate DateTime @default(now())
  status      String   @default("Present")
  shift       String   @default("Morning")
  address     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  leaveRequests LeaveRequest[]
  payslips      Payslip[]

  @@map("Staff")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEAVE REQUEST
// ─────────────────────────────────────────────────────────────────────────────
model LeaveRequest {
  id      String @id @default(uuid())
  staffId String
  type    String
  dates   String
  days    Int
  status  String @default("Pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("LeaveRequest")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYSLIP
// ─────────────────────────────────────────────────────────────────────────────
model Payslip {
  id            String @id @default(uuid())
  staffId       String
  baseSalary    Float
  overtimeHours Float  @default(0)
  deductions    Float  @default(0)
  bonus         Float  @default(0)
  totalPay      Float
  status        String @default("Processing")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@map("Payslip")
}
